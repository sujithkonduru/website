    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-validator": "^7.0.1",
    "framer-motion": "^12.34.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "react-countup": "^6.5.3",
    "react-parallax-tilt": "^1.7.319",
    "react-simple-typewriter": "^5.0.1",
    "swiper": "^12.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
