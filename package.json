{
  "name": "stackenzo-backend",
  "version": "1.0.0",
  "description": "Backend API for Stackenzo Education Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node backend/src/config/initDatabase.js",
    "build": "npm install  --prefix client && npm run build --prefix client",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "education",
    "api",
    "nodejs",
    "express",
    "mysql"
  ],
  "author": "Stackenzo",
  "license": "MIT",
